# PostgreSQL
DATABASE_URL=postgresql+asyncpg://marketing_user:marketing_pass@localhost:5432/adstudioai

# Meta / Facebook Graph API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v21.0
META_REDIRECT_URI=http://localhost:8000/api/v1/auth/meta/callback
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# WhatsApp Embedded Signup — crie em:
# Meta App Dashboard > WhatsApp > Configuração > Embedded Signup > Configurations
WHATSAPP_CONFIG_ID=your_whatsapp_embedded_signup_config_id

# Token encryption (Fernet) — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# n8n event dispatching (optional — leave blank to log only)
N8N_WEBHOOK_URL=

# Security
SECRET_KEY=change_this_to_a_random_secret_key
CORS_ORIGINS=["http://localhost:5173"]

# Super admins do sistema (emails separados por vírgula). Podem bloquear/
# liberar módulos (whatsapp, instagram, ads, ia) de QUALQUER conta — as
# agências fazem o mesmo só com as empresas-filhas (plan_type "dependente").
SUPER_ADMIN_EMAILS=admin@suaempresa.com

# ---------------------------------------------------------------------------
# IA de atendimento (Gemini 2.5 Flash + RAG)
# ---------------------------------------------------------------------------
# Redis — debounce da IA, rate limit anti-loop e dedup de webhook.
# No docker-compose já é injetado (redis://redis:6379/0). Vazio = fallback
# em memória (ok em 1 processo; use Redis em produção/multi-worker).
REDIS_URL=redis://redis:6379/0

# A API key da Gemini é POR TENANT (cada conta cola a dela no painel:
# Atendimento > IA & Conhecimento). É criptografada com a FERNET_KEY acima —
# NÃO é uma env global. Pegue uma em https://aistudio.google.com (grátis).

# Defaults de comportamento da IA (opcionais — já têm valor no código)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
AI_DEBOUNCE_SECONDS=3
AI_REQUEST_TIMEOUT=10
AI_DEFAULT_TOKEN_LIMIT=1000000
